# Exemple de fichier .env pour Inspection Platform
# Copiez ce fichier en .env et mettez vos valeurs

DEBUG=False
SECRET_KEY=your-production-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# SQLite local pour dev
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL pour production
DB_ENGINE=django.db.backends.postgresql
DB_NAME=inspection_platform
DB_USER=inspection_user
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME=28800
JWT_REFRESH_TOKEN_LIFETIME=604800

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-frontend-domain.com
